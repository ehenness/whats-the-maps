<!DOCTYPE html>
<html>
<head>
  <title>Leaderboard</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('./partials/banner.ejs') %>

  <%- include('./partials/footer.ejs') %>

  <main class="page-shell page-shell--centered">
    <section class="page-card table-card">
      <h1 class="page-title">Leaderboard</h1>

      <% if (leaderboard.length === 0) { %>
        <p class="page-subtitle">No scores have been saved yet.</p>
      <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Rank</th>
              <th>Username</th>
              <th>High Score</th>
            </tr>
          </thead>
          <tbody>
            <% leaderboard.forEach((entry, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td>
                  <a
                    class="username"
                    href="<%= Number(entry.user_id) === Number(locals.user?.id) ? '/dashboard' : `/players/${entry.user_id}` %>"
                  >
                    <%= entry.username %>
                  </a>
                </td>
                <td><%= entry.high_score %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </main>

</body>
</html>
