<!DOCTYPE html>
<html>
    <head>

    </head>
    <body style="background-color: antiquewhite; margin: 0;">
        <!--Header-->
        <%- include('./partials/banner.ejs') %>
        <% if (user) { %>
            <div style="margin: 5px; font-weight: bold;">
                <a href="/dashboard" style="text-decoration: none; color: black;">
                    <%= user.username %>
                </a>
            </div>
        <% } %>
        <div class="circle" style="height: 30px; width: 30px; background-color: grey; border-radius: 50%; float: left; margin: 3px;">
        </div>
        <div style="float: right; margin: 3px;">
            <% if (user) { %>
                <a href="/users/logout" style="text-decoration: none;">
                    <div style="height: 30px; width: 75px; text-align: center; background-color: bisque; border-style: solid;">
                        <h3 style="margin: 0; margin-top: 5px;">Log Out</h3>
                    </div>
                </a>
            <% } else { %>
                <a href="/login" style="text-decoration: none;">
                    <div style="height: 30px; width: 75px; text-align: center; background-color: bisque; border-style: solid;">
                        <h3 style="margin: 0; margin-top: 5px;">Log In</h3>
                    </div>
                </a>
            <% } %>
        </div>
        <div class="oval" style="height: 150px; width: 350px; border-radius: 50%; background-color: aqua; transform: rotate(165deg); position: fixed; inset: 0px; width: 350px; height:150px; max-width: 100vw; max-height: 100dvh; margin: auto; display: flex; justify-content: center; align-items: center;">
            <h1 style="transform: rotate(195deg); text-align: center;">Start a Mapch!</h1>
        </div>
        <!--Footer-->
        <%- include('./partials/footer.ejs') %>
    </body>
</html>