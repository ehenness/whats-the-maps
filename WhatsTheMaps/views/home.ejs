<!DOCTYPE html>
<html>
<head>
  <title>What's The Maps?</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('./partials/banner.ejs') %>

  <div class="mapch-popup" id="mapch-popup"><%- include('./partials/mapch-popup.ejs') %></div>

  <main class="page-shell page-stack page-stack--wide home-shell">
    <div class="top-bar">
      <div class="left-section">
        <% if (user) { %>
          <a class="profile-pic" href="/dashboard" aria-label="Open dashboard">
            <% if (user.profileImageUrl) { %>
              <img class="profile-pic__image" src="<%= user.profileImageUrl %>" alt="<%= user.username %>'s profile picture">
            <% } %>
          </a>
          <a class="username" href="/dashboard"><%= user.username %></a>
        <% } %>
      </div>

      <div>
        <% if (user) { %>
          <a class="button-link" href="/users/logout">
            <span class="button">Log Out</span>
          </a>
        <% } else { %>
          <a class="button-link" href="/login">
            <span class="button">Log In</span>
          </a>
        <% } %>
      </div>
    </div>

    <div class="home-hero">
      <% if (randomCity) { %>
        <a class="hero-blob hero-blob-link" href="/cities/<%= randomCity.cityId %>/game" aria-label="Start a random city quiz">
          <h1>Start a Mapch!</h1>
        </a>
      <% } else { %>
        <section class="hero-blob">
          <h1>Start a Mapch!</h1>
        </section>
      <% } %>
    </div>
  </main>

  <%- include('./partials/footer.ejs') %>

  <script>
    function mapchPopup() {
      document.getElementById("mapch-popup").style.display = "block";
      document.getElementById("mapch-button").style.display = "none";
    }

    function mapchBack() {
      document.getElementById("mapch-popup").style.display = "none";
      document.getElementById("mapch-button").style.display = "block";
    }
  </script>
</body>
</html>
