<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('./partials/banner.ejs') %>

  <main class="page-shell page-stack page-stack--wide">
    <div class="top-bar">
      <div class="left-section">
        <% if (user) { %>
          <a class="profile-pic" href="/dashboard" aria-label="Open dashboard"></a>
          <a class="username" href="/dashboard"><%= user.username %></a>
        <% } %>
      </div>

      <div>
        <% if (user) { %>
          <a class="button-link" href="/users/logout">
            <span class="button">Log Out</span>
          </a>
        <% } else { %>
          <a class="button-link" href="/login">
            <span class="button">Log In</span>
          </a>
        <% } %>
      </div>
    </div>

    <section class="hero-blob">
      <h1>Start a Mapch!</h1>
    </section>
  </main>

  <%- include('./partials/footer.ejs') %>
</body>
</html>
