<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('./partials/banner.ejs') %>

  <div class="city-popup" id="city-info"><%- include('./partials/city-popup.ejs') %></div>

  <main class="page-shell page-shell--centered">
    <section class="page-stack page-stack--wide">
      <h1 class="page-title">Cities!</h1>

      <div class="page-card page-card--flush">
        <div class="cities-controls">
          <div>Sort By: ___</div>
          <div>Random!</div>
        </div>
      </div>

      <section class="cities-list">
        <article class="city-item">
          <button class="city-name-button" id="city-button" onclick="cityPopup()"> City Name </button>
          <p>City Information (Foundation, Country, Language)</p>
        </article>

        <article class="city-item">
          <h3>City Name</h3>
          <p>City Information (Foundation, Country, Language)</p>
        </article>

        <article class="city-item">
          <h3>City Name</h3>
          <p>City Information (Foundation, Country, Language)</p>
        </article>
      </section>
    </section>
  </main>

  <%- include('./partials/footer.ejs') %>

  <script>
    function cityPopup() {
      document.getElementById("city-info").style.display = "block";
      document.getElementById("city-button").style.display = "none";
    }

    function cityBack() {
      document.getElementById("city-info").style.display = "none";
      document.getElementById("city-button").style.display = "block";
    }
  </script>

</body>
</html>
