<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('./partials/banner.ejs') %>

  <%- include('./partials/footer.ejs') %>

  <div class="city-popup" id="city-info"><%- include('./partials/city-popup.ejs') %></div>

  <main class="page-shell page-shell--centered">
    <section class="page-stack page-stack--wide">
      <h1 class="page-title">Cities</h1>

      <section class="page-card section-stack">
        <h2 class="page-title">Find a City Quiz</h2>

        <form class="cities-filter-form" action="/cities" method="GET">
          <div class="cities-controls">
            <div class="filter-control">
              <label class="form-label" for="state-filter">State</label>
              <select class="form-input" id="state-filter" name="state">
                <option value="all" <%= selectedState === 'all' ? 'selected' : '' %>>All States</option>
                <% states.forEach((state) => { %>
                  <option value="<%= state %>" <%= selectedState === state ? 'selected' : '' %>><%= state %></option>
                <% }) %>
              </select>
            </div>

            <div class="filter-control">
              <label class="form-label" for="sort-filter">Alphabetical</label>
              <select class="form-input" id="sort-filter" name="sort">
                <option value="alpha-asc" <%= selectedSort === 'alpha-asc' ? 'selected' : '' %>>A to Z</option>
                <option value="alpha-desc" <%= selectedSort === 'alpha-desc' ? 'selected' : '' %>>Z to A</option>
              </select>
            </div>
          </div>

          <div class="cities-filter-actions">
            <button class="button button-primary" type="submit">Apply Filters</button>
            <% if (randomCity) { %>
              <a class="button-link" href="/cities/<%= randomCity.cityId %>/game">
                <span class="button">Random City Quiz</span>
              </a>
            <% } %>
          </div>
        </form>
      </section>

      <section class="cities-list">
        <% if (cities.length === 0) { %>
          <section class="page-card section-stack">
            <h2 class="page-title">No Cities Found</h2>
            <p class="page-subtitle">Try a different state or sort option.</p>
          </section>
        <% } %>

        <% cities.forEach((city) => { %>
          <article class="city-item">
            <div class="city-copy">
              <div class="city-name-wrap">
                <h3 class="city-name"><%= city.cityName %></h3>
                <% if (city.cityInfo && city.cityInfo.length > 0) { %>
                  <div class="city-hover-card" role="tooltip">
                    <p class="city-hover-title"><%= city.cityName %>, <%= city.state %></p>
                    <% city.cityInfo.forEach((info) => { %>
                      <p class="city-hover-line">
                        <strong><%= info.label %>:</strong> <%= info.value %>
                      </p>
                    <% }) %>
                  </div>
                <% } %>
              </div>
              <p class="city-state"><%= city.state %></p>
              <p><%= city.description %></p>
            </div>

            <div class="city-actions">
              <a class="button-link" href="/cities/<%= city.cityId %>/game">
                <span class="button button-primary">Play Quiz</span>
              </a>
            </div>
          </article>
        <% }) %>
      </section>
    </section>
  </main>

</body>
</html>
