<%# Renders the shared error page for missing routes and server-side failures. %>
<!DOCTYPE html>
<html>
<head>
  <title>Error</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%# Shared site chrome appears on every page. %>
  <%- include('./partials/banner.ejs') %>

  <%- include('./partials/footer.ejs') %>

  <main class="page-shell page-shell--centered">
    <section class="page-card section-stack">
      <h1 class="page-title">Something Went Wrong</h1>
      <p class="page-subtitle"><%= message %></p>

      <%# Detailed stack traces are only available when the server passes them in %>
      <% if (error) { %>
        <pre class="error-stack"><%= error.stack %></pre>
      <% } %>

      <div>
        <a class="button-link" href="/">
          <span class="button">Go Home</span>
        </a>
      </div>
    </section>
  </main>

</body>
</html>
