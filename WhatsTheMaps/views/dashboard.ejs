<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('./partials/banner.ejs') %>

  <main class="page-shell page-shell--centered">
    <section class="page-stack page-stack--wide">
      <div class="page-card">
        <div class="dashboard-header">
          <div class="profile-pic profile-pic--large">Profile Picture</div>

          <div class="user-description">
            <h1><%= user.username %></h1>
            <p>Short description of the user's choosing. <br> Favorite City: ___ <br> Favorite Color: ___</p>
          </div>

          <a class="button-link" href="/users/logout">
            <span class="button">Log Out</span>
          </a>
        </div>
      </div>

      <div class="stats-grid">
        <section class="stats-card">
          <h3>Your Stats</h3>
          <p>Quizzes Played: __ <br> Questions Correct: __ <br> Your Rank: __</p>
        </section>

        <section class="stats-card">
          <h3>Global Stats</h3>
          <p>Quizzes Played: __ <br> Questions Correct: __ <br> Best Rank: __</p>
        </section>
      </div>

      <section class="page-card section-stack">
        <h2 class="page-title">Account Settings</h2>

        <form class="form-inline" action="/users/delete-account" method="POST">
          <label class="form-label" for="delete-password">Confirm with your password:</label>
          <input class="form-input" id="delete-password" name="password" type="password" required>
          <button
            class="button button-danger"
            type="submit"
            onclick="return confirm('Are you sure you want to delete your account? This cannot be undone.')"
          >
            Delete Account
          </button>
        </form>
      </section>
    </section>
  </main>

  <%- include('./partials/footer.ejs') %>
</body>
</html>
