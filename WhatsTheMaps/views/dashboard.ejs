<!DOCTYPE html>
    <html>
    <head>
    </head>
    <body style="margin: 0; background-color: antiquewhite;">
        <!--Header-->
        <%- include('./partials/banner.ejs') %>

        <!--User-->
        <div class="topRow" style="display: flex; width: 100%; height: 40%; justify-content: space-between;">
            <div class="circle" href="/dashboard" style="height: 150px; width: 150px; background-color: grey; border-radius: 50%; margin-left: 5px; margin-top: 20px; text-align: center; display: flex; justify-content: center; align-items: center;">Profile Picture</div>

            <div class="userDescription" style="text-align: center;">
                <h1>Username</h1>
                <p>Short description of the user's choosing. <br> Favorite City: ___ <br> Favorite Color: ___</p>
            </div>

            <a href="/users/logout" style="text-decoration: none; margin: 0; float: right; margin-right: 1%;">
                <div style="height: 30px; width: 75px; text-align: center; background-color: bisque; border-style: solid;">
                    <h3 style="margin: 0; margin-top: 5px;">Log Out</h3>
                </div>
            </a>
        </div>

        <!--leaderboard-->
        <div class="leaderboard" style="display: flex; justify-content: center; width: 100%; margin-top: 1%; position: fixed; top: 70%;">
            <div class="userStats" style="border-style: solid; width: 40%;">
                <h3 style="text-align: center; margin: 0;">Your Stats</h3>
                <p style="padding-left: 5px;">Quizzes Played: __ <br> Questions Right: __ <br> Your Rank: __</p>
            </div>
            <div class="rankedStats" style="border-style: solid; width: 40%;">
                <h3 style="text-align: center; margin: 0;">Global Stats</h3>
                <p style="padding-left: 5px;">Quizzes Played: __ <br> Questions Right: __ <br> #1 Rank: __</p>
            </div>
        </div>

        <!--Footer-->
        <%- include('./partials/footer.ejs') %>
    </body>
</html>