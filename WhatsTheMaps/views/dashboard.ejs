<%# Renders the player dashboard in profile-view or profile-edit mode %>
<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%# Shared site chrome appears on every page %>
  <%- include('./partials/banner.ejs') %>

  <%- include('./partials/footer.ejs') %>

  <main class="page-shell page-shell--centered">
    <section class="page-stack page-stack--wide">
      <%# Flash messages confirm profile updates or explain failures %>
      <% if (successMessage) { %>
        <p class="message message-success"><%= successMessage %></p>
      <% } %>

      <% if (errorMessage) { %>
        <p class="message message-error"><%= errorMessage %></p>
      <% } %>

      <% if (isEditing) { %>
        <%# Edit mode for changing avatar, bio, and account settings %>
        <section class="page-card section-stack dashboard-summary-card">
          <div class="dashboard-header">
            <label class="profile-pic profile-pic--large profile-picture-display edit-avatar-label" for="profile-image-upload">
              <img
                class="profile-pic__image <%= profile.profileImageUrl ? '' : 'hidden' %>"
                id="profile-image-preview"
                src="<%= profile.profileImageUrl || '' %>"
                alt="Current profile picture preview"
              >
              <span
                id="profile-image-placeholder"
                class="<%= profile.profileImageUrl ? 'hidden' : '' %>"
              >
                Profile Picture
              </span>
              <span class="edit-avatar-caption">Click to change</span>
            </label>

            <div class="user-description">
              <h1>Edit Profile</h1>
              <p>Choose a picture, update your bio, and save when you're ready to head back to your dashboard.</p>
            </div>

            <div class="dashboard-actions">
              <a class="button-link" href="/dashboard">
                <span class="button">Cancel</span>
              </a>
              <a class="button-link" href="/users/logout">
                <span class="button">Log Out</span>
              </a>
            </div>
          </div>
        </section>

        <section class="page-card section-stack">
          <h2 class="page-title">Profile Settings</h2>

          <%# Settings form supports preset avatars, uploaded images, short bio %>
          <form class="settings-form" action="/users/update-profile" method="POST">
            <div class="settings-section">
              <h3>Choose a Profile Picture</h3>

              <% if (presetAvatars.length > 0) { %>
                <div class="avatar-picker">
                  <% presetAvatars.forEach((avatarPath) => { %>
                    <label class="avatar-option">
                      <input
                        type="radio"
                        name="selectedAvatar"
                        value="<%= avatarPath %>"
                        <%= profile.profileImageUrl === avatarPath ? 'checked' : '' %>
                      >
                      <span class="avatar-swatch">
                        <img src="<%= avatarPath %>" alt="Preset avatar option">
                      </span>
                    </label>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="settings-note">No preset pictures found yet.</p>
              <% } %>

              <input class="file-input-hidden" id="profile-image-upload" type="file" accept="image/*">
              <input id="uploaded-image-data" name="uploadedImageData" type="hidden">
            </div>

            <div class="settings-section">
              <h3>Edit Your Bio</h3>
              <div class="form-group">
                <label class="form-label" for="bio">Tell other players about yourself</label>
                <textarea class="form-input form-textarea" id="bio" name="bio" maxlength="500"><%= profile.bio %></textarea>
              </div>
            </div>

            <div class="settings-actions">
              <button class="button button-primary" type="submit">Save Changes</button>
              <a class="button-link" href="/dashboard">
                <span class="button">Back to Dashboard</span>
              </a>
            </div>
          </form>
        </section>

        <section class="page-card section-stack">
          <h2 class="page-title">Danger Zone</h2>
          <%# Account deletion requires password confirmation before the server applies it %>
          <form class="delete-account-form" action="/users/delete-account" method="POST">
            <label class="form-label" for="delete-password">Confirm your password to delete your account</label>
            <div class="form-inline">
              <input class="form-input" id="delete-password" name="password" type="password" required>
              <button
                class="button button-danger"
                type="submit"
                onclick="return confirm('Are you sure you want to delete your account? This cannot be undone.')"
              >
                Delete Account
              </button>
            </div>
          </form>
        </section>
      <% } else { %>
        <%# Read-only mode shows profile summary and lifetime player stats %>
        <section class="page-card section-stack dashboard-summary-card">
          <div class="dashboard-header">
            <div class="profile-pic profile-pic--large profile-picture-display">
              <% if (profile.profileImageUrl) { %>
                <img
                  class="profile-pic__image"
                  src="<%= profile.profileImageUrl %>"
                  alt="<%= profile.username %>'s profile picture"
                >
              <% } else { %>
                Profile Picture
              <% } %>
            </div>

            <div class="user-description">
              <h1><%= isReadOnlyProfile ? `${profile.username}'s Profile` : profile.username %></h1>
              <p>
                <%= profile.bio || (isReadOnlyProfile ? 'No bio added yet.' : 'Add your bio and choose a profile picture in edit mode.') %>
              </p>
            </div>

            <div class="dashboard-actions">
              <% if (isReadOnlyProfile) { %>
                <a class="button-link" href="/leaderboard">
                  <span class="button">Back to Leaderboard</span>
                </a>
                <% if (user) { %>
                  <a class="button-link" href="/dashboard">
                    <span class="button button-primary">My Dashboard</span>
                  </a>
                <% } %>
              <% } else { %>
                <a class="button-link" href="/dashboard?edit=1">
                  <span class="button button-primary">Edit Profile</span>
                </a>
                <a class="button-link" href="/users/logout">
                  <span class="button">Log Out</span>
                </a>
              <% } %>
            </div>
          </div>
        </section>

        <section class="page-card section-stack">
          <h2 class="page-title"><%= isReadOnlyProfile ? 'Player Stats' : 'Your Stats' %></h2>
          <div class="dashboard-copy">
            <p>Quizzes Played: <%= stats.quizzesPlayed %></p>
            <p>Total Points Earned: <%= stats.totalPoints %></p>
            <p>Best Score: <%= stats.bestScore %></p>
            <p>Average Score: <%= stats.averageScore %></p>
            <p>
              Highest Leaderboard Rank:
              <%= stats.highestLeaderboardRank ? `#${stats.highestLeaderboardRank}` : 'Not ranked yet' %>
            </p>
          </div>
        </section>
      <% } %>
    </section>
  </main>

  <% if (isEditing) { %>
    <%# Avatar upload previews only run on editable dashboard %>
    <script src="/javascript/dashboard.js"></script>
  <% } %>
</body>
</html>
