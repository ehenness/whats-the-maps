{
  "name": "whatsthemaps",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "test": "node --test",
    "test:node": "cross-env NODE_ENV=test node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "node --test --experimental-test-coverage",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up --build"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "cross-env": "^10.1.0",
    "debug": "~2.6.9",
    "ejs": "^5.0.1",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "http-errors": "~1.6.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2"
  }
}
